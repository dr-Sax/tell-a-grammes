# ── Caddyfile (cache strategy for stamped ES modules) ─────────────────────────
# Pairs with stamp-version.mjs. The .js URLs carry ?v=<commit> and change every
# deploy, so they can be cached forever; index.html must never be cached so the
# new ?v= references are always seen.
#
# Adjust the address and `root` to match your project; merge the header rules
# into your existing site block.

:{$PORT} {
	root * /app
	encode gzip

	# index.html is the freshness anchor — never cache it.
	@html {
		path / *.html
	}
	header @html Cache-Control "no-store"

	# Stamped JS is effectively content-addressed (?v=<commit>), so cache hard.
	# A new deploy = a new URL = a guaranteed fetch; old versions stay cached
	# harmlessly. (If you'd rather keep it dead simple, use "no-store" here too —
	# it just refetches each load, which is fine for a single-device install.)
	@js {
		path *.js
	}
	header @js Cache-Control "public, max-age=31536000, immutable"

	file_server
}
